<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Clinic List View -->
    <record id="view_hospital_clinic_list" model="ir.ui.view">
        <field name="name">hospital.clinic.list</field>
        <field name="model">hospital.clinic</field>
        <field name="arch" type="xml">
            <list string="Clinics">
                <field name="name"/>
                <field name="open_datetime"/>
                <field name="end_datetime"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Clinic Form View -->
    <record id="view_hospital_clinic_form" model="ir.ui.view">
        <field name="name">hospital.clinic.form</field>
        <field name="model">hospital.clinic</field>
        <field name="arch" type="xml">
            <form string="Clinic">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="open_datetime"/>
                        </group>
                        <group>
                            <field name="end_datetime"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open Clinic Screen -->
    <record id="action_hospital_clinic" model="ir.actions.act_window">
        <field name="name">Clinics</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.clinic</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new clinic.
            </p>
        </field>
    </record>

    <!-- Menu Structure -->
    <!-- Root Menu -->
    <menuitem id="menu_hospital_root" name="Hospital" sequence="10"/>

    <!-- Submenu for Clinics -->
    <menuitem id="menu_hospital_clinic" name="Clinics" parent="menu_hospital_root" action="action_hospital_clinic" sequence="10"/>

</odoo>
