{
  "name": "Odoo Dev Container",
  "dockerComposeFile": "docker-compose.yml",
  "service": "web",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
      },
      "extensions": [
        "ms-python.python",
        "redhat.vscode-xml",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "remoteUser": "odoo"
}
